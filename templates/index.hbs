<!DOCTYPE html>
<html>

    <head>
        <title>Wikipedia Link Suggestions</title>
        <meta charset="UTF-8" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="color-scheme" content="dark light" />
        <script src="/static/main.js"></script>
        <link rel="stylesheet" href="/static/style.css">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet">
    </head>

    <body>
        {{> header }}
        <main>
        <form id="suggestionForm" onsubmit="fetch_suggestions(event)">
          <input value="{{language}}" type="text" id="language"/>.wikipedia.org/wiki/
          <input value="{{title}}" type="text" id="title" />
          <label for="confidence_score">confidence score</label>
          <input
            type="number"
            min="0.4"
            max="1.0"
            step="0.1"
            value="{{confidence_score}}"
            class="range"
            id="confidence_score"
          />
          <button type="submit">Submit</button>
        </form>
        <article><pre id="wikitext">{{results.new_wikitext}}</pre></article>
       </main>
        
        
    </body>

</html>
